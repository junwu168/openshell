{
  "name": "@junwu168/openshell",
  "version": "0.1.4",
  "type": "module",
  "files": [
    "dist",
    "README.md"
  ],
  "bin": {
    "openshell": "./dist/cli/openshell.js"
  },
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "dependencies": {
    "@opencode-ai/plugin": "*",
    "diff": "*",
    "env-paths": "*",
    "shescape": "*",
    "ssh2": "*"
  },
  "devDependencies": {
    "@types/bun": "*",
    "testcontainers": "*",
    "typescript": "*"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepack": "npm run build",
    "openshell": "$npm_execpath scripts/openshell.ts",
    "server-registry": "$npm_execpath scripts/server-registry.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  }
}
